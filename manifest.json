{
  "manifest_version": 3,
  "name": "Jarvis: AI Voice Assistant & Browser Agent",
  "version": "2.0.0",
  "description": "Automate your browser with AI voice and text commands. Manage tabs, bookmarks, and boost productivity 100% offline with your AI agent.",

  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "bookmarks",
    "history",
    "downloads",
    "storage",
    "notifications",
    "scripting",
    "browsingData",
    "topSites",
    "tabGroups",
    "sessions",
    "alarms",
    "offscreen",
    "nativeMessaging"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Open Jarvis AI Agent",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "command-palette.js"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+J"
      },
      "description": "Open Jarvis side panel"
    },
    "toggle-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+J"
      },
      "description": "Open Jarvis command palette"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
